@model Parcial_Vilchez_Cristopher.Models.Curso

<div class="container mt-4">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-lg">
        <div class="card-footer bg-white p-4">
            @if (User.Identity.IsAuthenticated)
            {
                <form asp-controller="Matricula" asp-action="Inscribir" method="post">
                    <input type="hidden" name="cursoId" value="@Model.Id" />
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                        Confirmar Inscripción
                    </button>
                </form>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-warning btn-lg w-100 fw-bold">
                    Inicia sesión para inscribirte
                </a>
            }
        </div>
    </div>
</div>