@using Parcial_Vilchez_Cristopher.Models
@model Parcial_Vilchez_Cristopher.Models.Curso

<div class="container mt-4">
    <h2>Gestión de Matrículas: <strong>@Model.Nombre</strong></h2>
    <a asp-action="Index" class="btn btn-secondary mb-3"><i class="bi bi-arrow-left"></i> Volver al Panel</a>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm p-3">
        <table class="table">
            <thead>
                <tr>
                    <th>ID Usuario (Alumno)</th>
                    <th>Fecha Solicitud</th>
                    <th>Estado Actual</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mat in Model.Matriculas)
                {
                    <tr>
                        <td><small>@mat.UsuarioId</small></td>
                        <td>@mat.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="badge @(mat.Estado == EstadoMatricula.Pendiente ? "bg-warning text-dark" : (mat.Estado == EstadoMatricula.Confirmada ? "bg-success" : "bg-danger"))">
                                @mat.Estado
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <form asp-action="CambiarEstadoMatricula" method="post">
                                    <input type="hidden" name="matriculaId" value="@mat.Id" />
                                    <input type="hidden" name="cursoId" value="@Model.Id" />
                                    <input type="hidden" name="nuevoEstado" value="@EstadoMatricula.Confirmada" />
                                    <button type="submit" class="btn btn-sm btn-success" @(mat.Estado == EstadoMatricula.Confirmada ? "disabled" : "")>Confirmar</button>
                                </form>
                                <form asp-action="CambiarEstadoMatricula" method="post">
                                    <input type="hidden" name="matriculaId" value="@mat.Id" />
                                    <input type="hidden" name="cursoId" value="@Model.Id" />
                                    <input type="hidden" name="nuevoEstado" value="@EstadoMatricula.Cancelada" />
                                    <button type="submit" class="btn btn-sm btn-danger" @(mat.Estado == EstadoMatricula.Cancelada ? "disabled" : "")>Cancelar</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if(!Model.Matriculas.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted">No hay matrículas para este curso.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>